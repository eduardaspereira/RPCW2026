@prefix : <http://rpcw.di.uminho.pt/2026/untitled-ontology-32/> .
@prefix ns1: <http://www.semanticweb.org/joaomoura03/ontologies/2026/bibliotecatemporal/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://rpcw.di.uminho.pt/2026/untitled-ontology-32/> .

<http://rpcw.di.uminho.pt/2026/untitled-ontology-32> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/nome
:nome rdf:type owl:AnnotationProperty .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/refereEvento
:refereEvento rdf:type owl:AnnotationProperty .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/trabalhamEm
:trabalhamEm rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/existemEm
:existemEm rdf:type owl:ObjectProperty ;
           rdfs:domain :Livro ;
           rdfs:range :LinhaTemporal .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/ocorremEm
:ocorremEm rdf:type owl:ObjectProperty ;
           rdfs:domain :Evento ;
           rdfs:range :LinhaTemporal .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/pertencemA
:pertencemA rdf:type owl:ObjectProperty ;
            rdfs:domain :Livro ;
            rdfs:range :Biblioteca .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/refereA
:refereA rdf:type owl:ObjectProperty .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/requisitam
:requisitam rdf:type owl:ObjectProperty ;
            rdfs:domain :Leitor ;
            rdfs:range :Livro .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/sãoEscritosPor
:sãoEscritosPor rdf:type owl:ObjectProperty ;
                rdfs:domain :Livro ;
                rdfs:range :Autor .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/trabalhaEm
:trabalhaEm rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ;
            rdfs:range :Biblioteca .


#################################################################
#    Classes
#################################################################

###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/Agente
:Agente rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/Autor
:Autor rdf:type owl:Class ;
       rdfs:subClassOf :Pessoa .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/Biblioteca
:Biblioteca rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/Bibliotecário
:Bibliotecário rdf:type owl:Class ;
               rdfs:subClassOf :Pessoa ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :trabalhaEm ;
                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                 owl:onClass :Biblioteca
                               ] .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/Empréstimo
:Empréstimo rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/Entidade_Temporal
:Entidade_Temporal rdf:type owl:Class ;
                   rdfs:subClassOf :Agente .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/Evento
:Evento rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/EventoFuturo
:EventoFuturo rdf:type owl:Class ;
              rdfs:subClassOf :Evento .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/EventoHistórico
:EventoHistórico rdf:type owl:Class ;
                 rdfs:subClassOf :Evento .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/Leitor
:Leitor rdf:type owl:Class ;
        rdfs:subClassOf :Pessoa .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/LinhaAlternativa
:LinhaAlternativa rdf:type owl:Class ;
                  rdfs:subClassOf :LinhaTemporal .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/LinhaOriginal
:LinhaOriginal rdf:type owl:Class ;
               rdfs:subClassOf :LinhaTemporal .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/LinhaTemporal
:LinhaTemporal rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/Livro
:Livro rdf:type owl:Class ;
       rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :existemEm ;
                         owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onClass :LinhaTemporal
                       ] .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/LivroFiccional
:LivroFiccional rdf:type owl:Class ;
                rdfs:subClassOf :Livro ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :refereA ;
                                  owl:allValuesFrom [ rdf:type owl:Class ;
                                                      owl:complementOf :EventoHistórico
                                                    ]
                                ] ;
                owl:disjointWith :LivroHistórico .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/LivroHistórico
:LivroHistórico rdf:type owl:Class ;
                rdfs:subClassOf :Livro ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :refereA ;
                                  owl:allValuesFrom :EventoHistórico
                                ] .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/LivroParadoxal
:LivroParadoxal rdf:type owl:Class ;
                rdfs:subClassOf :Livro ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :existemEm ;
                                  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :LinhaAlternativa
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :existemEm ;
                                  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :LinhaOriginal
                                ] .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/Pessoa
:Pessoa rdf:type owl:Class ;
        rdfs:subClassOf :Agente .


