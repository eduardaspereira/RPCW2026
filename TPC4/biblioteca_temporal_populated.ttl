                      :Linha_Original_00 ;
           :pertencemA :Arquivo_do_Vazio_Temporal ;
           :sãoEscritosPor :Autor_10 ;
           :refereEvento :Queda_do_Muro .


###  http://rpcw.di.uminho.pt/2026/untitled-ontology-32/Livro_002
:Livro_002 rdf:type owl:NamedIndividual ,
