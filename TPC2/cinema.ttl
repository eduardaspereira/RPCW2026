:F_Madagáscar2 rdf:type owl:NamedIndividual ,
                        :Filme ;
               :foiRealizado :P_EricDarnell ,
                             :P_TomMcGrath ;
               :temAtor :P_JadaSmith ;
               :temGénero :G_Aventura ,
                          :G_Infantil ;
               :temPaísOrigem :País_EUA ;
               :Data "2008-11-7" ;
               :Duração 89 ;
               :temTítulo "Madagascar: Escape 2 Africa" .


