@prefix : <http://rpcw.di.uminho.pt/2026/cinema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://rpcw.di.uminho.pt/2026/cinema#> .

<http://rpcw.di.uminho.pt/2026/cinema> rdf:type owl:Ontology ;
                                        rdfs:comment "Uma ontologia sobre cinema"@pt .

#################################################################
#    Object Properties
#################################################################

###  http://rpcw.di.uminho.pt/2026/cinema#Atuou
:Atuou rdf:type owl:ObjectProperty ;
       owl:inverseOf :temAtor ;
       rdfs:domain :Pessoa ;
       rdfs:range :Filme .


###  http://rpcw.di.uminho.pt/2026/cinema#Compôs
:Compôs rdf:type owl:ObjectProperty ;
        owl:inverseOf :foiComposta ;
        rdfs:domain :Pessoa ;
        rdfs:range :Obra .


###  http://rpcw.di.uminho.pt/2026/cinema#escreveu
:escreveu rdf:type owl:ObjectProperty ;
          owl:inverseOf :foiEscrito ;
          rdfs:domain :Pessoa ;
          rdfs:range :Obra .


###  http://rpcw.di.uminho.pt/2026/cinema#foiComposta
:foiComposta rdf:type owl:ObjectProperty ;
             rdfs:domain :Obra ;
             rdfs:range :Pessoa .


###  http://rpcw.di.uminho.pt/2026/cinema#foiEscrito
:foiEscrito rdf:type owl:ObjectProperty ;
            rdfs:domain :Obra ;
            rdfs:range :Pessoa .


###  http://rpcw.di.uminho.pt/2026/cinema#foiRealizado
:foiRealizado rdf:type owl:ObjectProperty ;
              owl:inverseOf :realizou ;
              rdfs:domain :Filme ;
              rdfs:range :Pessoa .


###  http://rpcw.di.uminho.pt/2026/cinema#interpreta
:interpreta rdf:type owl:ObjectProperty ;
            owl:inverseOf :éInterpretadoPor ;
            rdfs:domain :Pessoa ;
            rdfs:range :Personagem .


###  http://rpcw.di.uminho.pt/2026/cinema#realizou
:realizou rdf:type owl:ObjectProperty ;
          rdfs:domain :Pessoa ;
          rdfs:range :Filme .


###  http://rpcw.di.uminho.pt/2026/cinema#temArgumento
:temArgumento rdf:type owl:ObjectProperty ;
              rdfs:domain :Filme ;
              rdfs:range :Argumento .


###  http://rpcw.di.uminho.pt/2026/cinema#temAtor
:temAtor rdf:type owl:ObjectProperty ;
         rdfs:domain :Filme ;
         rdfs:range :Pessoa .


###  http://rpcw.di.uminho.pt/2026/cinema#temGénero
:temGénero rdf:type owl:ObjectProperty ;
           rdfs:domain :Filme ;
           rdfs:range :Género .


###  http://rpcw.di.uminho.pt/2026/cinema#temLíngua
:temLíngua rdf:type owl:ObjectProperty ;
           rdfs:domain :Filme ;
           rdfs:range :Língua .


###  http://rpcw.di.uminho.pt/2026/cinema#temPaísOrigem
:temPaísOrigem rdf:type owl:ObjectProperty ;
               rdfs:domain :Filme ;
               rdfs:range :País .


###  http://rpcw.di.uminho.pt/2026/cinema#temPersonagem
:temPersonagem rdf:type owl:ObjectProperty ;
               owl:inverseOf :éPersonagemDe ;
               rdfs:domain :Filme ;
               rdfs:range :Personagem .


###  http://rpcw.di.uminho.pt/2026/cinema#temPeçaMusical
:temPeçaMusical rdf:type owl:ObjectProperty ;
                rdfs:domain :Filme ;
                rdfs:range :PeçaMusical .


###  http://rpcw.di.uminho.pt/2026/cinema#éInterpretadoPor
:éInterpretadoPor rdf:type owl:ObjectProperty ;
                  rdfs:domain :Personagem ;
                  rdfs:range :Pessoa .


###  http://rpcw.di.uminho.pt/2026/cinema#éPersonagemDe
:éPersonagemDe rdf:type owl:ObjectProperty ;
               rdfs:domain :Personagem ;
               rdfs:range :Filme ;
               owl:propertyChainAxiom ( :éInterpretadoPor
                                        :Atuou
                                      ) .


#################################################################
#    Data properties
#################################################################

###  http://rpcw.di.uminho.pt/2026/cinema#Data
:Data rdf:type owl:DatatypeProperty ;
      rdfs:domain :Filme ;
      rdfs:range xsd:string .


###  http://rpcw.di.uminho.pt/2026/cinema#Duração
:Duração rdf:type owl:DatatypeProperty ;
         rdfs:domain :Filme ;
         rdfs:range xsd:integer .


###  http://rpcw.di.uminho.pt/2026/cinema#temSexo
:temSexo rdf:type owl:DatatypeProperty ;
         rdfs:domain :Pessoa ;
         rdfs:range xsd:string .


###  http://rpcw.di.uminho.pt/2026/cinema#temTítulo
:temTítulo rdf:type owl:DatatypeProperty ;
           rdfs:domain :Filme ;
           rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://rpcw.di.uminho.pt/2026/cinema#Argumento
:Argumento rdf:type owl:Class ;
           rdfs:subClassOf :Obra .


###  http://rpcw.di.uminho.pt/2026/cinema#Ator
:Ator rdf:type owl:Class ;
      owl:equivalentClass [ owl:intersectionOf ( :Pessoa
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :Atuou ;
                                                   owl:someValuesFrom :Filme
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] .


###  http://rpcw.di.uminho.pt/2026/cinema#Ator_Feminino
:Ator_Feminino rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :Ator
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :temSexo ;
                                                            owl:hasValue "F"
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               owl:disjointWith :Ator_Masculino .


###  http://rpcw.di.uminho.pt/2026/cinema#Ator_Masculino
:Ator_Masculino rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Ator
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :temSexo ;
                                                             owl:hasValue "M"
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] .


###  http://rpcw.di.uminho.pt/2026/cinema#Escritor
:Escritor rdf:type owl:Class ;
          owl:equivalentClass [ owl:intersectionOf ( :Pessoa
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty :escreveu ;
                                                       owl:someValuesFrom [ rdf:type owl:Class ;
                                                                            owl:unionOf ( :Argumento
                                                                                          :Livro
                                                                                        )
                                                                          ]
                                                     ]
                                                   ) ;
                                rdf:type owl:Class
                              ] ;
          rdfs:subClassOf :Pessoa .


###  http://rpcw.di.uminho.pt/2026/cinema#Filme
:Filme rdf:type owl:Class ;
       rdfs:subClassOf [ rdf:type owl:Restriction ;
                         owl:onProperty :Data ;
                         owl:someValuesFrom xsd:string
                       ] ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :Duração ;
                         owl:someValuesFrom xsd:integer
                       ] .


###  http://rpcw.di.uminho.pt/2026/cinema#FilmeAventura
:FilmeAventura rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :temGénero ;
                                                            owl:hasValue :G_Aventura
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf :Filme .


###  http://rpcw.di.uminho.pt/2026/cinema#FilmeAção
:FilmeAção rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :temGénero ;
                                                        owl:hasValue :G_Ação
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] .


###  http://rpcw.di.uminho.pt/2026/cinema#FilmeDramático
:FilmeDramático rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :temGénero ;
                                                             owl:hasValue :G_Drama
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] .


###  http://rpcw.di.uminho.pt/2026/cinema#FilmeFicção
:FilmeFicção rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :temGénero ;
                                                          owl:hasValue :G_Ficção
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] .


###  http://rpcw.di.uminho.pt/2026/cinema#FilmeInfantil
:FilmeInfantil rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :temGénero ;
                                                            owl:hasValue :G_Infantil
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
               rdfs:subClassOf :Filme .


###  http://rpcw.di.uminho.pt/2026/cinema#FilmeRomântico
:FilmeRomântico rdf:type owl:Class ;
                owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty :temGénero ;
                                                             owl:hasValue :G_Romance
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] .


###  http://rpcw.di.uminho.pt/2026/cinema#FilmeThriller
:FilmeThriller rdf:type owl:Class ;
               owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :temGénero ;
                                                            owl:hasValue :G_Thriller
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] .


###  http://rpcw.di.uminho.pt/2026/cinema#FilmesInteressantes
:FilmesInteressantes rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty :temGénero ;
                                                                  owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                                                                  owl:onClass :Género
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] .


###  http://rpcw.di.uminho.pt/2026/cinema#Género
:Género rdf:type owl:Class ;
        owl:equivalentClass [ rdf:type owl:Class ;
                              owl:oneOf ( :G_Aventura
                                          :G_Ação
                                          :G_Comédia
                                          :G_Drama
                                          :G_Ficção
                                          :G_Infantil
                                          :G_Romance
                                          :G_Terror
                                          :G_Thriller
                                        )
                            ] .


###  http://rpcw.di.uminho.pt/2026/cinema#Livro
:Livro rdf:type owl:Class ;
       rdfs:subClassOf :Obra .


###  http://rpcw.di.uminho.pt/2026/cinema#LongasMetragens
:LongasMetragens rdf:type owl:Class ;
                 owl:equivalentClass [ owl:intersectionOf ( :Filme
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty :Duração ;
                                                              owl:someValuesFrom [ rdf:type rdfs:Datatype ;
                                                                                   owl:onDatatype xsd:integer ;
                                                                                   owl:withRestrictions ( [ xsd:minInclusive 60
                                                                                                          ]
                                                                                                        )
                                                                                 ]
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] .


###  http://rpcw.di.uminho.pt/2026/cinema#Língua
:Língua rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/cinema#Músico
:Músico rdf:type owl:Class ;
        owl:equivalentClass [ owl:intersectionOf ( :Pessoa
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :Compôs ;
                                                     owl:someValuesFrom :PeçaMusical
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] .


###  http://rpcw.di.uminho.pt/2026/cinema#Obra
:Obra rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/cinema#País
:País rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/cinema#Personagem
:Personagem rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/cinema#Pessoa
:Pessoa rdf:type owl:Class .


###  http://rpcw.di.uminho.pt/2026/cinema#PeçaMusical
:PeçaMusical rdf:type owl:Class ;
             rdfs:subClassOf :Obra .


###  http://rpcw.di.uminho.pt/2026/cinema#Realizador
:Realizador rdf:type owl:Class ;
            owl:equivalentClass [ owl:intersectionOf ( :Pessoa
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :realizou ;
                                                         owl:someValuesFrom :Filme
                                                       ]
                                                     ) ;
                                  rdf:type owl:Class
                                ] .


#################################################################
#    Individuals
#################################################################

