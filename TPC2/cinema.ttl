:F_Interstellar rdf:type owl:NamedIndividual ,
                         :Filme ;
                :temGénero :G_Ação ,
                           :G_Drama ,
                           :G_Ficção ,
                           :G_Thriller ;
                :temLíngua :L_En ;
                :temPaísOrigem :País_EUA ;
                :Data "2014" ;
                :Duração 169 ;
                :temTítulo "Interstellar" .


